# Production domains
FRONTEND_URL=https://sello.webportfolio.uz
API_URL=https://selloapi.webportfolio.uz

# API
API_HOST=0.0.0.0
API_PORT=8000
API_HOST_PORT=8000
API_ENV=production
API_CORS_ORIGINS=https://sello.webportfolio.uz
API_DATABASE_URL=postgresql+asyncpg://sello:replace-db-password@postgres:5432/sello
API_REDIS_URL=redis://redis:6379/0
API_JWT_SECRET=replace-with-a-long-random-production-secret
API_JWT_ALGORITHM=HS256
API_ACCESS_TOKEN_EXPIRE_MINUTES=10080
OAUTH_TOKEN_ENCRYPTION_KEY=replace-with-fernet-key
OAUTH_TOKEN_ENCRYPTION_KEY_VERSION=v1
OAUTH_TOKEN_REFRESH_WINDOW_DAYS=7

# AI
GROQ_API_KEY=replace-with-groq-key
GROQ_MODEL=llama-3.1-8b-instant

# Meta / Instagram
META_APP_ID=replace-with-meta-app-id
META_APP_SECRET=replace-with-meta-app-secret
META_VERIFY_TOKEN=replace-with-meta-webhook-verify-token
META_GRAPH_API_VERSION=v20.0
META_OAUTH_CALLBACK_URL=https://selloapi.webportfolio.uz/auth/meta/callback
INSTAGRAM_WEBHOOK_URL=https://selloapi.webportfolio.uz/webhooks/instagram

# Web
NEXT_PUBLIC_API_URL=https://selloapi.webportfolio.uz
WEB_HOST_PORT=3000

# Database
POSTGRES_USER=sello
POSTGRES_PASSWORD=replace-db-password
POSTGRES_DB=sello

# Redis
REDIS_PORT=6379
